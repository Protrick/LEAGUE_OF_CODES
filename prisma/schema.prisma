// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  rooms        Room[]   @relation("RoomParticipants")
  hostedRooms  Room[]   @relation("RoomHost")
}

model Room {
  id           String   @id @default(cuid())
  roomCode     String   @unique
  hostId       String
  host         User     @relation("RoomHost", fields: [hostId], references: [id], onDelete: Cascade)
  participants User[]   @relation("RoomParticipants")
  status       String   @default("waiting") // waiting, active, completed
  
  // Question details
  selectedTitle      String?
  selectedTitleSlug  String?
  selectedDifficulty String?
  selectedTopic      String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
